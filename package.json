{
  "name": "hono-forge",
  "version": "0.2.0",
  "description": "NestJS-style decorators for Hono — DI container, routing, guards, SSE, WebSocket, channels, OpenAPI, and more.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "prepublishOnly": "bun run type-check && bun test && bun run build"
  },
  "keywords": [
    "hono",
    "hono-forge",
    "decorator",
    "typescript",
    "dependency-injection",
    "controller",
    "guard",
    "middleware",
    "sse",
    "websocket",
    "openapi",
    "channels",
    "bun",
    "edge"
  ],
  "dependencies": {
    "reflect-metadata": ">=0.2"
  },
  "peerDependencies": {
    "hono": ">=4",
    "zod": ">=4"
  },
  "devDependencies": {
    "@swc/core": "^1.15.33",
    "@types/bun": "latest",
    "hono": "^4.12.16",
    "reflect-metadata": "^0.2.2",
    "tsup": "^8.5.1",
    "typescript": "^5.5.0",
    "zod": "^4.4.2"
  }
}
